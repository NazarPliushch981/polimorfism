<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Document</title>
</head>
<body>
    <h2>Document</h2>
    <div id="tableOutput"></div>

    <script>
        class Employee {
            constructor(name, position, salary) {
                this.name = name;
                this.position = position;
                this.salary = salary;
            }
        }

        class EmpTable {
            constructor(empArray) {
                this.employees = empArray;
            }
            getHtml() {
                let html = "<table border='1'>";
                html += "<tr><th>ПІБ</th><th>Посада</th><th>Зарплата</th></tr>";
                for(let i = 0; i < this.employees.length; i++) {
                    let emp = this.employees[i];
                    html += "<tr><td>" + emp.name + "</td><td>" + emp.position + "</td><td>" + emp.salary + " грн</td></tr>";
                }
                html += "</table>";
                return html;
            }
        }

        class StyledEmpTable extends EmpTable {
            getStyles() {
                return `<style>
                    table { width: 100%; border-collapse: collapse; font-family: sans-serif; }
                    th { background-color: #4CAF50; color: white; padding: 10px; }
                    td { padding: 8px; background-color: #f2f2f2; border: 1px solid #ddd; }
                    tr:hover td { background-color: #ddd; }
                </style>`;
            }

            getHtml() {
                return this.getStyles() + super.getHtml();
            }
        }

        let bankEmployees = [
            new Employee("Іванов І.І.", "Менеджер", 25000),
            new Employee("Петров П.П.", "Касир", 18000),
            new Employee("Сидоров С.С.", "Директор", 50000)
        ];

        let styledTableObj = new StyledEmpTable(bankEmployees);
        document.getElementById("tableOutput").innerHTML = styledTableObj.getHtml();
    </script>
</body>
</html>
