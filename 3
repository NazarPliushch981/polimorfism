<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Document</title>
</head>
<body>
    <h2>Завдання 3: Працівники банку</h2>
    <div id="tableOutput"></div>

    <script>
        class Employee {
            constructor(name, position, salary) {
                this.name = name;
                this.position = position;
                this.salary = salary;
            }
        }


        let bankEmployees = [
            new Employee("Іванов І.І.", "Менеджер", 15000),
            new Employee("Шевченко П.П.", "Касир", 18500),
            new Employee("Шевцов С.С.", "Директор", 81000)
        ];

        class EmpTable {
            constructor(empArray) {
                this.employees = empArray;
            }

            getHtml() {
                let html = "<table border='1'>";
                html += "<tr><th>ПІБ</th><th>Посада</th><th>Зарплата</th></tr>";
                
                for(let i = 0; i < this.employees.length; i++) {
                    let emp = this.employees[i];
                    html += "<tr><td>" + emp.name + "</td><td>" + emp.position + "</td><td>" + emp.salary + " грн</td></tr>";
                }
                html += "</table>";
                return html;
            }
        }

        let tableObj = new EmpTable(bankEmployees);
        document.getElementById("tableOutput").innerHTML = tableObj.getHtml();
    </script>
</body>
</html>
